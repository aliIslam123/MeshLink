<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chat"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="To Broadcast"
        android:textSize="13sp"
        android:textColor="#8E8E93"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/btnDeviceSetup"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center"
            android:background="#E5E5EA">

            <View
                android:id="@+id/greenDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="#4CD964" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device Setup"
                android:textSize="12sp"
                android:textColor="#000000"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvBroadcast"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Broadcast"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#007AFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvDevices"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Devices"
            android:gravity="center"
            android:textColor="#007AFF"
            android:textSize="13sp"
            android:background="#E5E5EA"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#F2F2F7"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/linearMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#F2F2F7"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:textColorHint="#C7C7CC"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#FFFFFF"
            android:textSize="15sp"
            android:textColor="#000000"
            android:maxLines="3"
            android:inputType="textMultiLine|textCapSentences" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#007AFF"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:contentDescription="Send" />
    </LinearLayout>

</LinearLayout>
